{
  "name": "ramp",
  "version": "0.0.0",
  "private": true,
  "description": "Provable Agent Spend — a deterministic Datalog policy gate for agent payments.",
  "type": "module",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.13.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter @ramp/dashboard dev",
    "db:reset": "pnpm --filter @ramp/ledger db:reset",
    "mcp": "pnpm --filter @ramp/payments-mcp start",
    "build:wasm": "pnpm --filter @ramp/gate build:wasm",
    "clean": "pnpm -r exec rm -rf dist dist-test"
  },
  "dependencies": {
    "@ramp/gate": "workspace:*",
    "@ramp/ledger": "workspace:*",
    "@ramp/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
