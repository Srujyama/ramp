{
  "name": "ramp",
  "version": "0.0.0",
  "private": true,
  "description": "Warrant \u2014 a deterministic Datalog policy gate for agent payments.",
  "type": "module",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.13.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter @ramp/dashboard dev",
    "db:reset": "pnpm --filter @ramp/ledger db:reset",
    "db:history": "pnpm --filter @ramp/ledger db:history",
    "setup": "pnpm db:reset && pnpm db:history",
    "bridge": "pnpm --filter @ramp/ledger bridge",
    "control-plane": "pnpm --filter @ramp/control-plane start",
    "mcp": "pnpm --filter @ramp/payments-mcp start",
    "build:wasm": "pnpm --filter @ramp/gate build:wasm",
    "clean": "pnpm -r exec rm -rf dist dist-test",
    "demo": "node scripts/demo.mjs",
    "demo:deploy": "node scripts/demo-deploy.mjs",
    "notary": "node scripts/notary.mjs",
    "proof": "node scripts/audit.mjs",
    "approve": "node scripts/approve.mjs",
    "head": "node scripts/head.mjs",
    "stats": "node scripts/stats.mjs",
    "explain": "node scripts/explain.mjs",
    "simulate": "node scripts/simulate.mjs",
    "policy-diff": "node scripts/policy-diff.mjs",
    "receipt": "node scripts/receipt.mjs",
    "redteam": "node scripts/redteam.mjs",
    "sdk-example": "node scripts/sdk-example.mjs",
    "buy": "node scripts/buy.mjs"
  },
  "dependencies": {
    "@ramp/gate": "workspace:*",
    "@ramp/ledger": "workspace:*",
    "@ramp/shared": "workspace:*",
    "@ramp/quarantine": "workspace:*",
    "@ramp/attestation": "workspace:*",
    "@ramp/provenance": "workspace:*",
    "@ramp/client": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
