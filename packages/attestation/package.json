{
  "name": "@ramp/attestation",
  "version": "0.0.0",
  "private": true,
  "description": "Warrant — TLSNotary-style invoice attestation. Ed25519-signed statements binding invoice bytes to a vendor's TLS session, verified out of band. NOT the TLSNotary MPC protocol — see README.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "pretest": "tsc",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@ramp/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.3"
  }
}
