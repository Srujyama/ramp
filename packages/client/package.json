{
  "name": "@ramp/client",
  "version": "0.0.0",
  "private": true,
  "description": "Provable Agent Spend — the typed agent SDK. Build a spending agent on the gate in a few lines: pay, preview, budget, approval, decisions.",
  "type": "module",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
