  "dependencies": {
    "@ramp/shared": "workspace:*",
    "@ramp/gate": "workspace:*",
    "@ramp/ledger": "workspace:*",
    "@ramp/attestation": "workspace:*"
  },
  "devDependencies": { "@types/node": "^24.0.0", "typescript": "^5.7.3" }
}
