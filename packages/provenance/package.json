{
  "name": "@ramp/provenance",
  "version": "0.0.0",
  "private": true,
  "description": "Warrant \u2014 the provenance graph. Content-addressed decision bundles that an auditor can independently re-verify: decision -> facts -> each fact's authoritative source.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "pretest": "tsc",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@ramp/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.3"
  }
}
